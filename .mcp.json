{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "deep-research": {
      "command": "uvx",
      "args": [
        "mcp-server-deep-research"
      ]
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "github-actions": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github-actions"
      ],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "pytest": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-pytest"
      ]
    },
    "ref": {
      "command": "npx",
      "args": [
        "ref-tools-mcp@latest"
      ],
      "env": {
        "REF_API_KEY": "${REF_API_KEY}"
      }
    },
    "sqlalchemy": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlalchemy"
      ],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "storybook": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    },
    "databricks": {
      "command": "/Users/dpal/.ai-dev-kit/.venv/bin/python",
      "args": [
        "/Users/dpal/.ai-dev-kit/repo/databricks-mcp-server/run_server.py"
      ],
      "defer_loading": true,
      "env": {
        "DATABRICKS_CONFIG_PROFILE": "DEFAULT"
      }
    }
  }
}
