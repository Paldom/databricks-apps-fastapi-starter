# Local core app settings
ENVIRONMENT=development
LOG_LEVEL=INFO
ENABLE_DOCS=true
SERVE_STATIC=false
FRONTEND_DIST_DIR=frontend/dist
ENABLE_LEGACY_API=false
VOLUME_ROOT=/Volumes/main/default

# Local database settings (canonical)
# Run Postgres in Docker and the API on the host during local development.
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@127.0.0.1:5432/mydb
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=mydb
PGUSER=myuser
PGPASSWORD=mypassword

# Development auth fallback
ENABLE_LOCAL_DEV_AUTH_FALLBACK=true
LOCAL_DEV_USER_ID=local-dev-user

# Optional Databricks integrations
ENABLE_DATABRICKS_INTEGRATIONS=false
ENABLE_OBO=false
SERVING_ENDPOINT_NAME=
JOB_ID=
VECTOR_SEARCH_ENDPOINT_NAME=
VECTOR_SEARCH_INDEX_NAME=
KNOWLEDGE_ASSISTANT_ENDPOINT=
KNOWLEDGE_ASSISTANT_TIMEOUT_SECONDS=60

# Optional Databricks connectivity for local integrated mode
DATABRICKS_HOST=https://dummy.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abc123
DATABRICKS_TOKEN=
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Legacy LAKEBASE_* fallback (backwards compatible)
LAKEBASE_HOST=127.0.0.1
LAKEBASE_PORT=5432
LAKEBASE_DB=mydb
LAKEBASE_USER=myuser
LAKEBASE_PASSWORD=mypassword

# Request size limits (bytes)
MAX_REQUEST_BODY_BYTES=1048576
MAX_UPLOAD_BYTES=10485760

# Timeouts (seconds)
GENIE_TIMEOUT_SECONDS=30
SERVING_TIMEOUT_SECONDS=30
JOB_TIMEOUT_SECONDS=120
VECTOR_TIMEOUT_SECONDS=30
OPENAI_TIMEOUT_SECONDS=30
