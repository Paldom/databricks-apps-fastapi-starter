# Optional Databricks integrations
# When deployed via Databricks Asset Bundles, SERVING_ENDPOINT_NAME, JOB_ID,
# and VOLUME_ROOT are injected automatically via app resource bindings (valueFrom).
# Set these manually only for local development.
SERVING_ENDPOINT_NAME=
JOB_ID=
VECTOR_SEARCH_ENDPOINT_NAME=
VECTOR_SEARCH_INDEX_NAME=

# Knowledge Assistant (created in Agent Bricks, consumed as serving endpoint)
KNOWLEDGE_ASSISTANT_ENDPOINT=
KNOWLEDGE_ASSISTANT_TIMEOUT_SECONDS=60

# Databricks SQL Warehouse
DATABRICKS_HOST=dummy.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abc123
DATABRICKS_TOKEN=dapi1234567890abcdef

# Lakebase
LAKEBASE_HOST=127.0.0.1
LAKEBASE_PORT=5432
LAKEBASE_DB=mydb
LAKEBASE_USER=myuser
LAKEBASE_PASSWORD=mypassword

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
VOLUME_ROOT=/Volumes/main/default
# Optional: enable on-behalf-of-user WorkspaceClient
ENABLE_OBO=false

# Frontend serving
ENABLE_DOCS=true
SERVE_STATIC=false
FRONTEND_DIST_DIR=frontend/dist
ENABLE_LEGACY_API=false

# Cache
# Backend: "memory" (default, in-process) or "redis"
CACHE_ENABLED=true
CACHE_BACKEND=memory
CACHE_NAMESPACE=databricks-apps-fastapi-starter
CACHE_DEFAULT_TTL=60
CACHE_TIMEOUT=1
# Redis-only (used when CACHE_BACKEND=redis)
CACHE_REDIS_ENDPOINT=localhost
CACHE_REDIS_PORT=6379
CACHE_REDIS_DB=0
# CACHE_REDIS_PASSWORD=

# Rate limiting
# Set to false to disable rate limiting (useful for development)
RATE_LIMIT_ENABLED=true

# Request size limits (bytes)
MAX_REQUEST_BODY_BYTES=1048576
MAX_UPLOAD_BYTES=10485760

# Timeouts (seconds)
GENIE_TIMEOUT_SECONDS=30
SERVING_TIMEOUT_SECONDS=30
JOB_TIMEOUT_SECONDS=120
VECTOR_TIMEOUT_SECONDS=30
OPENAI_TIMEOUT_SECONDS=30

# Health
HEALTH_READY_CACHE_TTL=30

# SQLAlchemy
# DATABASE_URL corresponds to the database connection string used by Alembic
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@127.0.0.1:5432/mydb
