# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@127.0.0.1:5432/mydb

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
ENABLE_DOCS=true
SERVE_STATIC=false

# Development auth fallback
ENABLE_LOCAL_DEV_AUTH_FALLBACK=true
LOCAL_DEV_USER_ID=local-dev-user

# Databricks connectivity (for local dev against a real Databricks workspace)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
# Or use client credentials instead of token:
# DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET=

# Request size limits (bytes)
MAX_REQUEST_BODY_BYTES=1048576
MAX_UPLOAD_BYTES=52428800

# Databricks integrations (disabled locally by default)
ENABLE_DATABRICKS_INTEGRATIONS=false
ENABLE_OBO=false
# SERVING_ENDPOINT_NAME=
# VECTOR_SEARCH_ENDPOINT_NAME=
# VECTOR_SEARCH_INDEX_NAME=
# KNOWLEDGE_ASSISTANT_ENDPOINT=
# VOLUME_ROOT=/Volumes/main/default

# Chat orchestrator
LANGGRAPH_MEMORY_BACKEND=inmemory
# SUPERVISOR_MODEL=
# APP_AGENT_NAME=
# SERVING_AGENT_ENDPOINT=
# SERVING_AGENT_API_MODE=responses
# GENIE_SPACE_ID=
# KNOWLEDGE_VOLUME_ROOT=
# AI_GATEWAY_EMBEDDING_MODEL=
ENABLE_CHAT_TITLE_GENERATION=true
# TITLE_MODEL=

# MLflow (auto-provisioned by bundle in deployed environments)
# MLFLOW_TRACKING_URI=databricks
# MLFLOW_REGISTRY_URI=databricks-uc
# MLFLOW_EXPERIMENT_ID=

# Optional local OTEL tracing (use `make dev-api-otel` instead of `make dev-api`)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=fastapi-starter-local
# OTEL_TRACES_SAMPLER=always_on
